---
interface Props {
  variant?: 'landing' | 'app';
}

const { variant = 'app' } = Astro.props;
const path = Astro.url.pathname;

const appNav = [
  { href: '/dashboard', label: 'Dashboard' },
  { href: '/results', label: 'Results' },
  { href: '/settings', label: 'Settings' },
];

const landingNav = [
  { href: '#features', label: 'Product' },
  { href: '#features', label: 'Features' },
  { href: '#pricing', label: 'Pricing' },
  { href: '/dashboard', label: 'Dashboard' },
];

const navLinks = variant === 'landing' ? landingNav : appNav;
---

<header class="sticky top-0 z-50 border-b border-white/5 bg-[#0a0a0a]/85 backdrop-blur-xl">
  <div class="mx-auto max-w-6xl px-6 h-16 flex items-center justify-between gap-6">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 no-underline shrink-0 group">
      <div class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0" style="background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 60%, #a855f7 100%);">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z" fill="white" fill-opacity="0.95"/>
          <circle cx="12" cy="10" r="3" fill="white" fill-opacity="0.45"/>
        </svg>
      </div>
      <span class="font-semibold text-white text-sm tracking-tight group-hover:text-zinc-200 transition-colors">LeadScraper</span>
    </a>

    <!-- Nav links -->
    <nav class="hidden md:flex items-center gap-0.5 flex-1 justify-center">
      {navLinks.map(({ href, label }) => {
        const active = variant === 'app' && (path === href || (href !== '/' && path.startsWith(href + '/')));
        return (
          <a
            href={href}
            class={`px-3 py-1.5 rounded-full text-sm transition-all no-underline ${
              active
                ? 'bg-white/10 text-white font-medium'
                : 'text-zinc-400 hover:text-white hover:bg-white/5'
            }`}
          >
            {label}
          </a>
        );
      })}
    </nav>

    <!-- CTAs -->
    <div class="flex items-center gap-2 shrink-0">
      {variant === 'landing' ? (
        <>
          <a
            href="/dashboard"
            class="hidden sm:flex items-center px-3.5 h-8 text-sm font-medium text-zinc-300 hover:text-white bg-white/5 hover:bg-white/8 rounded-lg border border-white/8 transition-all no-underline"
          >
            Sign in
          </a>
          <a
            href="/dashboard"
            class="flex items-center gap-1.5 px-3.5 h-8 text-sm font-medium text-black bg-white hover:bg-zinc-100 rounded-lg transition-all no-underline"
          >
            Get started
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </>
      ) : (
        <a
          href="/dashboard"
          class="flex items-center gap-1.5 px-3.5 h-8 text-sm font-medium text-black bg-white hover:bg-zinc-100 rounded-lg transition-all no-underline"
        >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          New search
        </a>
      )}
    </div>

  </div>
</header>
