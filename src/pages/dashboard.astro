---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import SearchForm from '../components/SearchForm';
---

<Layout title="Dashboard">
  <Navbar variant="app" />

  <main class="mx-auto max-w-5xl px-6 py-10">

    <!-- Page header -->
    <div class="mb-8">
      <div class="flex items-center gap-1.5 text-xs text-zinc-600 mb-3 font-mono">
        <a href="/" class="hover:text-zinc-400 transition-colors no-underline">Home</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-zinc-700"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-zinc-500">Dashboard</span>
      </div>
      <h1 class="text-2xl font-semibold text-white tracking-tight mb-1">Search Console</h1>
      <p class="text-zinc-500 text-sm">Find business leads by keyword and location using Google Maps data.</p>
    </div>

    <!-- Layout: search panel + sidebar -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

      <!-- Search panel -->
      <div class="lg:col-span-2">
        <div class="rounded-2xl border border-white/8 bg-zinc-900/40 p-6">
          <!-- Card header -->
          <div class="flex items-center gap-3 mb-6 pb-5 border-b border-white/5">
            <div class="w-9 h-9 rounded-xl border border-white/8 bg-white/5 flex items-center justify-center text-zinc-400 shrink-0">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            </div>
            <div>
              <h2 class="text-sm font-semibold text-white">New Search</h2>
              <p class="text-xs text-zinc-500">Scrape Google Maps for business data</p>
            </div>
          </div>
          <!-- React form component -->
          <SearchForm client:load />
        </div>
      </div>

      <!-- Sidebar -->
      <div class="flex flex-col gap-4">

        <!-- Cost warning -->
        <div class="rounded-2xl border border-amber-500/15 bg-amber-500/5 p-4">
          <div class="flex items-start gap-3">
            <div class="mt-0.5 text-amber-400 shrink-0">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-amber-400 mb-1">Apify Cost Estimate</p>
              <p class="text-xs text-zinc-500 leading-relaxed">
                Each search uses ~0.5–2 compute units. Apify's free tier includes 5 CU/month.
              </p>
            </div>
          </div>
        </div>

        <!-- Tips card -->
        <div class="rounded-2xl border border-white/8 bg-zinc-900/40 p-4">
          <p class="text-xs font-semibold text-zinc-300 mb-3 flex items-center gap-2">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-zinc-500"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Search tips
          </p>
          <ul class="space-y-2.5">
            {[
              'Use specific keywords — "Italian restaurants" beats "food"',
              'Add a city or region for targeted results',
              'Start with 50 results to test, then scale up',
              'Each search takes 1–3 minutes to complete',
            ].map((tip) => (
              <li class="flex items-start gap-2 text-xs text-zinc-500">
                <span class="text-zinc-700 mt-px shrink-0">·</span>
                {tip}
              </li>
            ))}
          </ul>
        </div>

        <!-- Quick links -->
        <div class="rounded-2xl border border-white/8 bg-zinc-900/40 p-4">
          <p class="text-xs font-semibold text-zinc-300 mb-3">Quick actions</p>
          <div class="space-y-1">
            <a
              href="/results"
              class="flex items-center gap-2.5 py-2 px-2 rounded-lg text-xs text-zinc-400 hover:text-white hover:bg-white/5 transition-all no-underline group"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-zinc-600 group-hover:text-zinc-400 transition-colors">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M3 9h18M9 21V9"/>
              </svg>
              View all leads
            </a>
            <a
              href="/api/export"
              class="flex items-center gap-2.5 py-2 px-2 rounded-lg text-xs text-zinc-400 hover:text-white hover:bg-white/5 transition-all no-underline group"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-zinc-600 group-hover:text-zinc-400 transition-colors">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Export leads to CSV
            </a>
            <a
              href="/settings"
              class="flex items-center gap-2.5 py-2 px-2 rounded-lg text-xs text-zinc-400 hover:text-white hover:bg-white/5 transition-all no-underline group"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-zinc-600 group-hover:text-zinc-400 transition-colors">
                <circle cx="12" cy="12" r="3"/>
                <path d="M19.07 4.93l-1.42 1.42M4.93 4.93l1.42 1.42M4.93 19.07l1.42-1.42M19.07 19.07l-1.42-1.42M12 2v2M12 20v2M2 12h2M20 12h2"/>
              </svg>
              Manage API keys
            </a>
          </div>
        </div>

      </div>
    </div>
  </main>
</Layout>
