---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import LinkedInSearchForm from '../../components/LinkedInSearchForm';
import DashboardQuickActions from '../../components/DashboardQuickActions';

const user = Astro.locals.user;
const displayName = user?.user_metadata?.full_name ?? user?.email?.split('@')[0] ?? 'there';
---

<Layout title="LinkedIn">
  <Navbar variant="app" />

  <main class="mx-auto max-w-5xl px-6 py-10">
    <div class="mb-8">
      <div class="flex items-center gap-1.5 text-xs text-[#a1a1a1] mb-3 font-mono">
        <a href="/" class="hover:text-[#4d4d4d] transition-colors no-underline">Home</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-[#d4d4d4]"><path d="m9 18 6-6-6-6"/></svg>
        <a href="/dashboard" class="hover:text-[#4d4d4d] transition-colors no-underline">Dashboard</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-[#d4d4d4]"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-[#888888]">LinkedIn</span>
      </div>
      <h1 class="text-2xl font-semibold text-[#171717] tracking-tight mb-1" style="letter-spacing: -0.6px;">LinkedIn Search</h1>
      <p class="text-[#888888] text-sm">Welcome back, {displayName}. Search LinkedIn profiles with filters.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
      <div class="lg:col-span-2">
        <div
          class="rounded-xl border border-[#ebebeb] bg-white p-6"
          style="box-shadow: 0px 1px 1px #00000005, 0px 2px 2px #0000000a;"
        >
          <div class="flex items-center gap-3 mb-6 pb-5 border-b border-[#ebebeb]">
            <div class="w-9 h-9 rounded-lg border border-[#ebebeb] bg-[#fafafa] flex items-center justify-center shrink-0">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <rect x="2" y="2" width="20" height="20" rx="3" fill="#0A66C2"/>
                <path d="M7 10v7M7 7.5v.01M11 17v-4.2c0-1.2.9-2.3 2.1-2.3s2.1 1 2.1 2.2V17M11 10.8V17" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div>
              <h2 class="text-sm font-semibold text-[#171717]">New Search</h2>
              <p class="text-xs text-[#888888]">Scrape LinkedIn profiles via Apify task</p>
            </div>
          </div>
          <LinkedInSearchForm client:load />
        </div>
      </div>

      <div class="flex flex-col gap-4">
        <div
          class="rounded-xl border border-[#ebebeb] bg-white p-4"
          style="box-shadow: 0px 1px 1px #00000005, 0px 2px 2px #0000000a;"
        >
          <p class="text-xs font-semibold text-[#171717] mb-3 flex items-center gap-2">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[#a1a1a1]"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Search tips
          </p>
          <ul class="space-y-2.5">
            {[
              'Use "Short" mode to test filters cheaply',
              'Company filters expect full LinkedIn company URLs',
              'Use "United Kingdom" instead of "UK" for locations',
              'Runs can take 30–90 seconds depending on mode',
            ].map((tip) => (
              <li class="flex items-start gap-2 text-xs text-[#888888]">
                <span class="text-[#d4d4d4] mt-px shrink-0">·</span>
                {tip}
              </li>
            ))}
          </ul>
        </div>

        <DashboardQuickActions client:load />
      </div>
    </div>
  </main>
</Layout>
