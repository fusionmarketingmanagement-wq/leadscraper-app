---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import SearchForm from '../../../components/SearchForm';
import DashboardQuickActions from '../../../components/DashboardQuickActions';

const user = Astro.locals.user;
const displayName = user?.user_metadata?.full_name ?? user?.email?.split('@')[0] ?? 'there';
---

<DashboardLayout title="Google Maps" pageTitle="Google Maps">
  <div class="mx-auto max-w-6xl min-w-0">
    <p class="text-[#888888] text-sm mb-6">
      Welcome back, {displayName}. Find business leads by keyword and location.
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
      <div class="lg:col-span-2">
        <div
          class="rounded-xl border border-[#ebebeb] bg-white p-4 sm:p-6"
          style="box-shadow: 0px 1px 1px #00000005, 0px 2px 2px #0000000a;"
        >
          <div class="flex items-center gap-3 mb-6 pb-5 border-b border-[#ebebeb]">
            <div class="w-9 h-9 rounded-lg border border-[#ebebeb] bg-[#fafafa] flex items-center justify-center text-[#888888] shrink-0">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <h2 class="text-sm font-semibold text-[#171717]">New Search</h2>
              <p class="text-xs text-[#888888]">Scrape Google Maps for business data</p>
            </div>
          </div>
          <SearchForm client:load />
        </div>
      </div>

      <div class="flex flex-col gap-4">
        <div class="rounded-xl border border-amber-200 bg-amber-50 p-4">
          <div class="flex items-start gap-3">
            <div class="mt-0.5 text-amber-600 shrink-0">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-amber-700 mb-1">Apify Cost Estimate</p>
              <p class="text-xs text-amber-600 leading-relaxed">
                Each search uses ~0.5–2 compute units. Apify's free tier includes 5 CU/month.
              </p>
            </div>
          </div>
        </div>

        <div
          class="rounded-xl border border-[#ebebeb] bg-white p-4"
          style="box-shadow: 0px 1px 1px #00000005, 0px 2px 2px #0000000a;"
        >
          <p class="text-xs font-semibold text-[#171717] mb-3 flex items-center gap-2">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[#a1a1a1]"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Search tips
          </p>
          <ul class="space-y-2.5">
            {[
              'Use specific keywords — "Italian restaurants" beats "food"',
              'Add a city or region for targeted results',
              'Start with 50 results to test, then scale up',
              'Each search takes 1–3 minutes to complete',
            ].map((tip) => (
              <li class="flex items-start gap-2 text-xs text-[#888888]">
                <span class="text-[#d4d4d4] mt-px shrink-0">·</span>
                {tip}
              </li>
            ))}
          </ul>
        </div>

        <DashboardQuickActions client:load />
      </div>
    </div>
  </div>
</DashboardLayout>
