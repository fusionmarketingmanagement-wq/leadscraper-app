---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const features = [
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    title: 'Google Maps Data',
    desc: 'Extract business listings from Google Maps using Apify\'s reliable crawler infrastructure.',
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>`,
    title: 'Structured Leads',
    desc: 'Company name, phone, email, website, address, rating, and social links — all in one clean record.',
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`,
    title: 'One-click CSV Export',
    desc: 'Download a clean CSV file ready for your CRM, email outreach tool, or spreadsheet.',
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
    title: 'Local Storage',
    desc: 'Leads are stored in a local SQLite database. Your data never leaves your machine.',
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>`,
    title: 'Smart Filters',
    desc: 'Filter by email found, phone available, website, or minimum rating to focus on qualified leads.',
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    title: 'Multi-language',
    desc: 'Search in English, Spanish, French, German, Japanese, and 6 more languages.',
  },
];

const steps = [
  {
    num: '01',
    title: 'Enter your search',
    desc: 'Type a business keyword like "dentists" or "Italian restaurants" and add a city or region.',
  },
  {
    num: '02',
    title: 'We scrape Google Maps',
    desc: 'Apify\'s crawler extracts business listings in real-time — takes 1 to 3 minutes.',
  },
  {
    num: '03',
    title: 'Export your leads',
    desc: 'Filter results, then download a clean CSV file ready for your outreach workflow.',
  },
];

const mockLeads = [
  { name: 'Parkside Dental NYC', rating: '4.9', phone: '+1 212 555-0147', web: 'parkside.dental' },
  { name: 'Manhattan Smiles', rating: '4.7', phone: '+1 646 555-0189', web: 'manhattansmiles.co' },
  { name: 'NYC Dental Studio', rating: '4.5', phone: '+1 917 555-0234', web: 'nycdental.io' },
  { name: 'Upper East Smiles', rating: '4.2', phone: '+1 212 555-0312', web: 'uppereast.dental' },
];
---

<Layout title="LeadScraper">
  <Navbar variant="landing" />

  <main>
    <!-- ─── HERO ──────────────────────────────────────── -->
    <section class="relative overflow-hidden pt-20 pb-32 px-6">
      <!-- Atmospheric gradient backdrop -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] rounded-full blur-3xl opacity-30" style="background: radial-gradient(ellipse, #6366f1 0%, #8b5cf6 30%, transparent 70%);"></div>
        <div class="absolute top-32 left-1/4 w-64 h-64 rounded-full blur-3xl opacity-15" style="background: #3b82f6;"></div>
        <div class="absolute top-32 right-1/4 w-64 h-64 rounded-full blur-3xl opacity-15" style="background: #a855f7;"></div>
      </div>

      <div class="relative mx-auto max-w-5xl">
        <!-- Badge -->
        <div class="flex justify-center mb-8">
          <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-white/10 bg-white/5 text-xs text-zinc-400">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 shrink-0"></span>
            Powered by Apify · Google Maps Scraper
          </div>
        </div>

        <!-- Headline -->
        <h1
          class="text-center text-5xl sm:text-6xl md:text-7xl font-semibold text-white leading-none mb-6"
          style="letter-spacing: -2.5px;"
        >
          Find verified business<br />
          <span class="text-zinc-400">leads in seconds.</span>
        </h1>

        <!-- Subheadline -->
        <p class="text-center text-lg text-zinc-400 leading-relaxed max-w-2xl mx-auto mb-10">
          Search by niche and location, collect public business data, enrich websites, and export clean leads to CSV.
        </p>

        <!-- CTAs -->
        <div class="flex items-center justify-center gap-3 flex-wrap mb-20">
          <a
            href="/dashboard"
            class="inline-flex items-center gap-2 px-6 h-12 text-base font-medium text-black bg-white hover:bg-zinc-100 rounded-full transition-all no-underline shadow-lg shadow-white/10"
          >
            Start scraping
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <a
            href="#demo"
            class="inline-flex items-center gap-2 px-6 h-12 text-base font-medium text-white border border-white/15 hover:bg-white/5 rounded-full transition-all no-underline"
          >
            View demo
          </a>
        </div>

        <!-- Dashboard preview card -->
        <div id="demo" class="relative mx-auto max-w-3xl">
          <div class="absolute -inset-2 rounded-3xl blur-3xl opacity-40 pointer-events-none" style="background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #a855f7 100%);"></div>
          <div class="relative rounded-2xl border border-white/10 bg-zinc-900/90 backdrop-blur-sm overflow-hidden shadow-2xl shadow-black/70">
            <!-- Browser chrome -->
            <div class="flex items-center gap-1.5 px-4 py-3 border-b border-white/5 bg-zinc-950/60">
              <div class="w-2.5 h-2.5 rounded-full bg-red-500/70"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/70"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-500/70"></div>
              <div class="ml-3 flex-1">
                <div class="mx-auto max-w-[200px] flex items-center gap-1.5 px-3 py-1 rounded bg-zinc-800/70 border border-white/5 text-[10px] text-zinc-500 font-mono">
                  <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0 opacity-60"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  leadscraper.io/dashboard
                </div>
              </div>
            </div>

            <!-- Search inputs mock -->
            <div class="p-5 border-b border-white/5">
              <div class="grid grid-cols-2 gap-3 mb-3">
                <div class="flex items-center gap-2 rounded-lg border border-white/10 bg-zinc-800/50 px-3 py-2.5">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-zinc-600 shrink-0"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                  <span class="text-sm text-zinc-300">dentists</span>
                </div>
                <div class="flex items-center gap-2 rounded-lg border border-white/10 bg-zinc-800/50 px-3 py-2.5">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-zinc-600 shrink-0"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  <span class="text-sm text-zinc-300">New York, US</span>
                </div>
              </div>
              <div class="w-full rounded-lg bg-white text-black text-sm font-medium py-2.5 text-center">
                Search Google Maps
              </div>
            </div>

            <!-- Sample leads table -->
            <div>
              <div class="grid grid-cols-4 px-5 py-2 border-b border-white/5 bg-zinc-950/40">
                <span class="text-[10px] text-zinc-600 font-mono uppercase tracking-wider">Company</span>
                <span class="text-[10px] text-zinc-600 font-mono uppercase tracking-wider">Rating</span>
                <span class="text-[10px] text-zinc-600 font-mono uppercase tracking-wider">Phone</span>
                <span class="text-[10px] text-zinc-600 font-mono uppercase tracking-wider">Website</span>
              </div>
              {mockLeads.map((lead, i) => (
                <div class={`grid grid-cols-4 px-5 py-3 border-b border-white/5 text-xs ${i % 2 === 1 ? 'bg-zinc-950/25' : ''}`}>
                  <span class="text-white font-medium truncate">{lead.name}</span>
                  <span class="text-emerald-400">★ {lead.rating}</span>
                  <span class="text-zinc-400">{lead.phone}</span>
                  <span class="text-indigo-400">{lead.web}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── LOGO CLOUD ─────────────────────────────────── -->
    <section class="border-y border-white/5 px-6 py-14">
      <div class="mx-auto max-w-5xl text-center">
        <p class="text-[10px] text-zinc-600 uppercase tracking-widest font-mono mb-8">Trusted by sales teams worldwide</p>
        <div class="flex items-center justify-center gap-10 flex-wrap">
          {['Startup Co', 'Agency XYZ', 'SalesPro', 'Outreach Inc', 'GrowthLab'].map((name) => (
            <span class="text-sm font-semibold text-zinc-700">{name}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── FEATURES ───────────────────────────────────── -->
    <section id="features" class="px-6 py-24">
      <div class="mx-auto max-w-5xl">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/8 bg-white/4 text-xs text-zinc-400 font-mono mb-4">
            Features
          </div>
          <h2 class="text-3xl sm:text-4xl font-semibold text-white mb-4" style="letter-spacing: -1px;">
            Everything you need to find leads.
          </h2>
          <p class="text-zinc-400 text-lg max-w-xl mx-auto">
            A complete toolkit for sourcing, enriching, and exporting business data at scale.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {features.map((f) => (
            <div class="group rounded-2xl border border-white/8 bg-zinc-900/30 p-6 hover:border-white/15 hover:bg-zinc-900/50 transition-all">
              <div
                class="w-9 h-9 rounded-xl border border-white/8 bg-white/5 flex items-center justify-center text-zinc-400 mb-4 group-hover:text-white group-hover:border-white/15 transition-all"
                set:html={f.icon}
              />
              <h3 class="text-sm font-semibold text-white mb-2">{f.title}</h3>
              <p class="text-sm text-zinc-500 leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── HOW IT WORKS ───────────────────────────────── -->
    <section class="px-6 py-24 border-t border-white/5">
      <div class="mx-auto max-w-5xl">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/8 bg-white/4 text-xs text-zinc-400 font-mono mb-4">
            How it works
          </div>
          <h2 class="text-3xl sm:text-4xl font-semibold text-white mb-4" style="letter-spacing: -1px;">
            From search to leads in minutes.
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {steps.map((step, i) => (
            <div class="relative">
              {i < steps.length - 1 && (
                <div class="hidden md:block absolute top-5 left-full w-full h-px bg-gradient-to-r from-white/10 to-transparent z-10 translate-x-3"></div>
              )}
              <div class="rounded-2xl border border-white/8 bg-zinc-900/30 p-6 h-full">
                <div class="text-xs font-mono text-zinc-600 mb-4">{step.num}</div>
                <h3 class="text-base font-semibold text-white mb-2">{step.title}</h3>
                <p class="text-sm text-zinc-500 leading-relaxed">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── DATA SAFETY ────────────────────────────────── -->
    <section class="px-6 py-24 border-t border-white/5">
      <div class="mx-auto max-w-5xl">
        <div class="rounded-2xl border border-white/8 bg-zinc-900/30 overflow-hidden">
          <div class="px-8 py-8 md:py-10 grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
            <div>
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-emerald-500/20 bg-emerald-500/8 text-xs text-emerald-400 font-mono mb-4">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                Private by default
              </div>
              <h2 class="text-2xl font-semibold text-white mb-3" style="letter-spacing: -0.5px;">Your data stays with you.</h2>
              <p class="text-zinc-400 leading-relaxed">
                LeadScraper stores all leads in a local SQLite database on your machine. API keys are server-side only, never exposed to the browser. We don't send your data anywhere.
              </p>
            </div>
            <div class="grid grid-cols-1 gap-3">
              {[
                { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`, label: 'Local SQLite database', sub: 'No cloud storage' },
                { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`, label: 'API keys server-side only', sub: 'Never exposed to browser' },
                { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`, label: 'No third-party sharing', sub: 'Your leads stay yours' },
              ].map((item) => (
                <div class="flex items-start gap-3 rounded-xl border border-white/6 bg-white/3 p-4">
                  <div class="mt-0.5 text-emerald-400 shrink-0" set:html={item.icon}/>
                  <div>
                    <p class="text-sm font-medium text-white">{item.label}</p>
                    <p class="text-xs text-zinc-500 mt-0.5">{item.sub}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── DATA FIELDS ────────────────────────────────── -->
    <section class="px-6 py-16 border-t border-white/5">
      <div class="mx-auto max-w-5xl">
        <div class="rounded-2xl border border-white/8 bg-zinc-900/30 overflow-hidden">
          <div class="px-6 py-5 border-b border-white/5">
            <h2 class="text-sm font-semibold text-white">16 data fields collected per lead</h2>
            <p class="text-xs text-zinc-500 mt-0.5">Everything you need to start your outreach.</p>
          </div>
          <div class="p-6 grid grid-cols-2 sm:grid-cols-4 gap-3">
            {[
              'Company Name', 'Category', 'Website', 'Phone',
              'Email', 'Address', 'City', 'Country',
              'Rating', 'Facebook', 'Twitter / X', 'LinkedIn',
              'Instagram', 'YouTube', 'Source URL', 'Search Query',
            ].map((field) => (
              <div class="flex items-center gap-2 text-sm">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-emerald-500 shrink-0">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span class="text-zinc-400">{field}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ─── PRICING ────────────────────────────────────── -->
    <section id="pricing" class="px-6 py-24 border-t border-white/5">
      <div class="mx-auto max-w-5xl">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/8 bg-white/4 text-xs text-zinc-400 font-mono mb-4">
            Pricing
          </div>
          <h2 class="text-3xl sm:text-4xl font-semibold text-white mb-4" style="letter-spacing: -1px;">
            Simple, transparent pricing.
          </h2>
          <p class="text-zinc-400 max-w-md mx-auto">
            LeadScraper is self-hosted. You pay only for your Apify usage.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">
          <!-- Free tier -->
          <div class="rounded-2xl border border-white/8 bg-zinc-900/30 p-7 flex flex-col">
            <div class="mb-5">
              <div class="text-xs font-mono text-zinc-500 uppercase tracking-widest mb-2">Starter</div>
              <div class="text-4xl font-semibold text-white mb-1" style="letter-spacing: -1px;">Free</div>
              <p class="text-sm text-zinc-500">Apify free tier · 5 CU/month</p>
            </div>
            <ul class="space-y-2.5 mb-7 flex-1">
              {['Up to 500 leads/month', 'CSV export', 'Local SQLite storage', 'Google Maps scraping', 'Multi-language search'].map((f) => (
                <li class="flex items-center gap-2.5 text-sm text-zinc-400">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-emerald-500 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="/dashboard" class="flex items-center justify-center h-10 rounded-xl border border-white/15 bg-white/5 text-sm font-medium text-white hover:bg-white/10 transition-all no-underline">
              Get started free
            </a>
          </div>

          <!-- Pro tier -->
          <div class="rounded-2xl border border-white/15 bg-white/5 p-7 flex flex-col relative overflow-hidden">
            <div class="absolute top-4 right-4">
              <span class="text-[10px] font-mono uppercase tracking-widest px-2.5 py-1 rounded-full bg-violet-500/15 text-violet-400 border border-violet-500/20">Coming soon</span>
            </div>
            <div class="mb-5">
              <div class="text-xs font-mono text-zinc-500 uppercase tracking-widest mb-2">Pro</div>
              <div class="text-4xl font-semibold text-white mb-1" style="letter-spacing: -1px;">$29<span class="text-xl text-zinc-500 font-normal">/mo</span></div>
              <p class="text-sm text-zinc-500">Unlimited Apify credits included</p>
            </div>
            <ul class="space-y-2.5 mb-7 flex-1">
              {['Everything in Starter', 'Unlimited leads', 'Email enrichment (Hunter.io)', 'Email verification (ZeroBounce)', 'Google Places enrichment', 'Priority support'].map((f) => (
                <li class="flex items-center gap-2.5 text-sm text-zinc-400">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-violet-400 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <button disabled class="flex items-center justify-center h-10 rounded-xl bg-white/10 text-sm font-medium text-zinc-500 cursor-not-allowed">
              Notify me when available
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── FINAL CTA ──────────────────────────────────── -->
    <section class="px-6 py-24 border-t border-white/5">
      <div class="mx-auto max-w-3xl">
        <div class="rounded-2xl border border-white/10 overflow-hidden relative" style="background: linear-gradient(135deg, #1a1030 0%, #0f0a1e 50%, #0a0a0a 100%);">
          <div class="absolute inset-0 pointer-events-none">
            <div class="absolute top-0 right-0 w-64 h-64 rounded-full blur-3xl opacity-20" style="background: #8b5cf6;"></div>
            <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full blur-3xl opacity-15" style="background: #6366f1;"></div>
          </div>
          <div class="relative px-8 py-14 text-center">
            <h2 class="text-3xl sm:text-4xl font-semibold text-white mb-4" style="letter-spacing: -1px;">
              Start finding leads today.
            </h2>
            <p class="text-zinc-400 text-lg mb-8 max-w-md mx-auto">
              Self-hosted, private, and free to start. All you need is a free Apify account.
            </p>
            <div class="flex items-center justify-center gap-3 flex-wrap">
              <a
                href="/dashboard"
                class="inline-flex items-center gap-2 px-6 h-12 text-base font-medium text-black bg-white hover:bg-zinc-100 rounded-full transition-all no-underline"
              >
                Open dashboard
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
              </a>
              <a
                href="/settings"
                class="inline-flex items-center gap-2 px-6 h-12 text-base font-medium text-white border border-white/15 hover:bg-white/5 rounded-full transition-all no-underline"
              >
                Configure API keys
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── FOOTER ─────────────────────────────────────── -->
    <footer class="border-t border-white/5 px-6 py-12">
      <div class="mx-auto max-w-5xl">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
          <div class="flex items-center gap-2.5">
            <div class="w-6 h-6 rounded-md flex items-center justify-center shrink-0" style="background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 60%, #a855f7 100%);">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z" fill="white" fill-opacity="0.9"/>
                <circle cx="12" cy="10" r="3" fill="white" fill-opacity="0.4"/>
              </svg>
            </div>
            <span class="text-sm font-semibold text-zinc-400">LeadScraper</span>
            <span class="text-zinc-700">·</span>
            <span class="text-xs text-zinc-600">leadscrape.io</span>
          </div>
