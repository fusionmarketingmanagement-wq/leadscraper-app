---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import AuthModal from '../components/AuthModal';

const user = Astro.locals.user;
const supabaseConfig = Astro.locals.supabaseConfig;

const features = [
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    title: 'Google Maps Data',
    desc: 'Extract business listings from Google Maps using Apify\'s reliable crawler infrastructure.',
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>`,
    title: 'Structured Leads',
    desc: 'Company name, phone, email, website, address, rating, and social links — all in one clean record.',
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`,
    title: 'One-click CSV Export',
    desc: 'Download a clean CSV file ready for your CRM, email outreach tool, or spreadsheet.',
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
    title: 'Local Storage',
    desc: 'Leads are stored securely in your Supabase database. Each user sees only their own data.',
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>`,
    title: 'Smart Filters',
    desc: 'Filter by email found, phone available, website, or minimum rating to focus on qualified leads.',
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    title: 'Multi-language',
    desc: 'Search in English, Spanish, French, German, Japanese, and 6 more languages.',
  },
];

const steps = [
  { num: '01', title: 'Enter your search', desc: 'Type a business keyword like "dentists" or "Italian restaurants" and add a city or region.' },
  { num: '02', title: 'We scrape Google Maps', desc: 'Apify\'s crawler extracts business listings in real-time — takes 1 to 3 minutes.' },
  { num: '03', title: 'Export your leads', desc: 'Filter results, then download a clean CSV file ready for your outreach workflow.' },
];

const mockLeads = [
  { name: 'Parkside Dental NYC', rating: '4.9', phone: '+1 212 555-0147', web: 'parkside.dental' },
  { name: 'Manhattan Smiles', rating: '4.7', phone: '+1 646 555-0189', web: 'manhattansmiles.co' },
  { name: 'NYC Dental Studio', rating: '4.5', phone: '+1 917 555-0234', web: 'nycdental.io' },
  { name: 'Upper East Smiles', rating: '4.2', phone: '+1 212 555-0312', web: 'uppereast.dental' },
];
---

<Layout title="LeadScraper">
  <Navbar variant="landing" />

  <main>
    <!-- ─── HERO ──────────────────────────────────────── -->
    <section class="relative overflow-hidden pt-20 pb-32 px-6 bg-white">
      <!-- Vercel-style mesh gradient atmospheric backdrop -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[600px] rounded-full blur-3xl opacity-[0.12]" style="background: radial-gradient(ellipse, #007cf0 0%, #00dfd8 35%, transparent 70%);"></div>
        <div class="absolute -top-10 left-1/3 w-80 h-80 rounded-full blur-3xl opacity-[0.08]" style="background: #7928ca;"></div>
        <div class="absolute -top-10 right-1/3 w-80 h-80 rounded-full blur-3xl opacity-[0.07]" style="background: #ff0080;"></div>
        <div class="absolute top-40 right-1/4 w-48 h-48 rounded-full blur-3xl opacity-[0.06]" style="background: #f9cb28;"></div>
      </div>

      <div class="relative mx-auto max-w-5xl">
        <!-- Badge -->
        <div class="flex justify-center mb-8">
          <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-[#ebebeb] bg-white text-xs text-[#4d4d4d]" style="box-shadow: 0px 1px 1px #00000005;">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 shrink-0"></span>
            Powered by Apify · Google Maps Scraper
          </div>
        </div>

        <!-- Headline -->
        <h1
          class="text-center text-5xl sm:text-6xl md:text-7xl font-semibold text-[#171717] leading-none mb-6"
          style="letter-spacing: -2.5px;"
        >
          Find verified business<br />
          <span class="text-[#888888]">leads in seconds.</span>
        </h1>

        <!-- Subheadline -->
        <p class="text-center text-lg text-[#4d4d4d] leading-relaxed max-w-2xl mx-auto mb-10">
          Search by niche and location, collect public business data from Google Maps, and export clean leads to CSV.
        </p>

        <!-- CTAs -->
        <div class="flex items-center justify-center gap-3 flex-wrap mb-20">
          {user ? (
            <a
              href="/dashboard"
              class="inline-flex items-center gap-2 px-6 h-12 text-base font-medium text-white bg-[#171717] hover:bg-[#2d2d2d] rounded-full transition-all no-underline"
              style="box-shadow: 0px 1px 1px #00000005, 0px 4px 8px -2px #0000001a;"
            >
              Go to dashboard
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          ) : (
            <button
              id="hero-cta-btn"
              class="inline-flex items-center gap-2 px-6 h-12 text-base font-medium text-white bg-[#171717] hover:bg-[#2d2d2d] rounded-full transition-all cursor-pointer"
              style="box-shadow: 0px 1px 1px #00000005, 0px 4px 8px -2px #0000001a;"
            >
              Start scraping free
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
            </button>
          )}
          <a
            href="#demo"
            class="inline-flex items-center gap-2 px-6 h-12 text-base font-medium text-[#171717] border border-[#ebebeb] bg-white hover:bg-[#fafafa] rounded-full transition-all no-underline"
          >
            View demo
          </a>
        </div>

        <!-- Dashboard preview card -->
        <div id="demo" class="relative mx-auto max-w-3xl">
          <div
            class="relative rounded-xl border border-[#ebebeb] bg-white overflow-hidden"
            style="box-shadow: 0px 1px 1px #00000005, 0px 8px 16px -4px #0000000a, 0px 24px 32px -8px #0000000f;"
          >
            <!-- Browser chrome -->
            <div class="flex items-center gap-1.5 px-4 py-3 border-b border-[#ebebeb] bg-[#fafafa]">
              <div class="w-2.5 h-2.5 rounded-full bg-red-400/80"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-400/80"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-400/80"></div>
              <div class="ml-3 flex-1">
                <div class="mx-auto max-w-[220px] flex items-center gap-1.5 px-3 py-1 rounded bg-white border border-[#ebebeb] text-[10px] text-[#888888] font-mono">
                  <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0 opacity-50"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  leadscraper.io/dashboard
                </div>
              </div>
            </div>

            <!-- Search inputs mock -->
            <div class="p-5 border-b border-[#ebebeb]">
              <div class="grid grid-cols-2 gap-3 mb-3">
                <div class="flex items-center gap-2 rounded-md border border-[#ebebeb] bg-white px-3 py-2.5">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[#a1a1a1] shrink-0"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                  <span class="text-sm text-[#171717]">dentists</span>
                </div>
                <div class="flex items-center gap-2 rounded-md border border-[#ebebeb] bg-white px-3 py-2.5">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[#a1a1a1] shrink-0"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  <span class="text-sm text-[#171717]">New York, US</span>
                </div>
              </div>
              <div class="w-full rounded-md bg-[#171717] text-white text-sm font-medium py-2.5 text-center">
                Search Google Maps
              </div>
            </div>

            <!-- Sample leads table -->
            <div>
              <div class="grid grid-cols-4 px-5 py-2.5 border-b border-[#ebebeb] bg-[#fafafa]">
                <span class="text-[10px] text-[#888888] font-mono uppercase tracking-wider">Company</span>
                <span class="text-[10px] text-[#888888] font-mono uppercase tracking-wider">Rating</span>
                <span class="text-[10px] text-[#888888] font-mono uppercase tracking-wider">Phone</span>
                <span class="text-[10px] text-[#888888] font-mono uppercase tracking-wider">Website</span>
              </div>
              {mockLeads.map((lead, i) => (
                <div class={`grid grid-cols-4 px-5 py-3 border-b border-[#ebebeb] text-xs ${i % 2 === 1 ? 'bg-[#fafafa]/60' : ''}`}>
                  <span class="text-[#171717] font-medium truncate">{lead.name}</span>
                  <span class="text-emerald-600">★ {lead.rating}</span>
                  <span class="text-[#4d4d4d]">{lead.phone}</span>
                  <span class="text-[#0070f3]">{lead.web}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── LOGO CLOUD ─────────────────────────────────── -->
    <section class="border-y border-[#ebebeb] px-6 py-12 bg-[#fafafa]">
      <div class="mx-auto max-w-5xl text-center">
        <p class="text-[10px] text-[#a1a1a1] uppercase tracking-widest font-mono mb-8">Trusted by sales teams worldwide</p>
        <div class="flex items-center justify-center gap-10 flex-wrap">
          {['Startup Co', 'Agency XYZ', 'SalesPro', 'Outreach Inc', 'GrowthLab'].map((name) => (
            <span class="text-sm font-semibold text-[#a1a1a1]">{name}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── FEATURES ───────────────────────────────────── -->
    <section id="features" class="px-6 py-24 bg-white">
      <div class="mx-auto max-w-5xl">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[#ebebeb] bg-[#fafafa] text-xs text-[#4d4d4d] font-mono mb-4">
            Features
          </div>
          <h2 class="text-3xl sm:text-4xl font-semibold text-[#171717] mb-4" style="letter-spacing: -1px;">
            Everything you need to find leads.
          </h2>
          <p class="text-[#4d4d4d] text-lg max-w-xl mx-auto">
            A complete toolkit for sourcing, enriching, and exporting business data at scale.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {features.map((f) => (
            <div
              class="group rounded-xl border border-[#ebebeb] bg-white p-6 hover:border-[#a1a1a1] transition-all"
              style="box-shadow: 0px 1px 1px #00000005, 0px 2px 2px #0000000a;"
            >
              <div
                class="w-9 h-9 rounded-lg border border-[#ebebeb] bg-[#fafafa] flex items-center justify-center text-[#888888] mb-4 group-hover:border-[#a1a1a1] group-hover:text-[#171717] transition-all"
                set:html={f.icon}
              />
              <h3 class="text-sm font-semibold text-[#171717] mb-2">{f.title}</h3>
              <p class="text-sm text-[#888888] leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── HOW IT WORKS ───────────────────────────────── -->
    <section class="px-6 py-24 border-t border-[#ebebeb] bg-[#fafafa]">
      <div class="mx-auto max-w-5xl">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[#ebebeb] bg-white text-xs text-[#4d4d4d] font-mono mb-4">
            How it works
          </div>
          <h2 class="text-3xl sm:text-4xl font-semibold text-[#171717] mb-4" style="letter-spacing: -1px;">
            From search to leads in minutes.
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {steps.map((step, i) => (
            <div class="relative">
              {i < steps.length - 1 && (
                <div class="hidden md:block absolute top-5 left-full w-full h-px bg-gradient-to-r from-[#ebebeb] to-transparent z-10 translate-x-3"></div>
              )}
              <div
                class="rounded-xl border border-[#ebebeb] bg-white p-6 h-full"
                style="box-shadow: 0px 1px 1px #00000005, 0px 2px 2px #0000000a;"
              >
                <div class="text-xs font-mono text-[#a1a1a1] mb-4">{step.num}</div>
                <h3 class="text-base font-semibold text-[#171717] mb-2">{step.title}</h3>
                <p class="text-sm text-[#888888] leading-relaxed">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── DATA FIELDS ────────────────────────────────── -->
    <section class="px-6 py-16 border-t border-[#ebebeb] bg-[#fafafa]">
      <div class="mx-auto max-w-5xl">
        <div
          class="rounded-xl border border-[#ebebeb] bg-white overflow-hidden"
          style="box-shadow: 0px 1px 1px #00000005, 0px 2px 2px #0000000a;"
        >
          <div class="px-6 py-5 border-b border-[#ebebeb]">
            <h2 class="text-sm font-semibold text-[#171717]">16 data fields collected per lead</h2>
            <p class="text-xs text-[#888888] mt-0.5">Everything you need to start your outreach.</p>
          </div>
          <div class="p-6 grid grid-cols-2 sm:grid-cols-4 gap-3">
            {[
              'Company Name', 'Category', 'Website', 'Phone',
              'Email', 'Address', 'City', 'Country',
              'Rating', 'Facebook', 'Twitter / X', 'LinkedIn',
              'Instagram', 'YouTube', 'Source URL', 'Search Query',
            ].map((field) => (
              <div class="flex items-center gap-2 text-sm">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-emerald-500 shrink-0">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span class="text-[#4d4d4d] text-xs">{field}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ─── PRICING ────────────────────────────────────── -->
    <section id="pricing" class="px-6 py-24 border-t border-[#ebebeb] bg-white">
      <div class="mx-auto max-w-5xl">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[#ebebeb] bg-[#fafafa] text-xs text-[#4d4d4d] font-mono mb-4">
            Pricing
          </div>
          <h2 class="text-3xl sm:text-4xl font-semibold text-[#171717] mb-4" style="letter-spacing: -1px;">
            Simple, transparent pricing.
          </h2>
          <p class="text-[#4d4d4d] max-w-md mx-auto">
            LeadScraper is self-hosted. You pay only for your Apify usage.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">
          <!-- Free tier -->
          <div
            class="rounded-xl border border-[#ebebeb] bg-white p-7 flex flex-col"
            style="box-shadow: 0px 1px 1px #00000005, 0px 2px 2px #0000000a, 0px 8px 16px -4px #0000000a;"
          >
            <div class="mb-5">
              <div class="text-xs font-mono text-[#a1a1a1] uppercase tracking-widest mb-2">Starter</div>
              <div class="text-4xl font-semibold text-[#171717] mb-1" style="letter-spacing: -1px;">Free</div>
              <p class="text-sm text-[#888888]">Apify free tier · 5 CU/month</p>
            </div>
            <ul class="space-y-2.5 mb-7 flex-1">
              {['Up to 500 leads/month', 'CSV export', 'Supabase cloud storage', 'Google Maps scraping', 'Multi-language search'].map((f) => (
                <li class="flex items-center gap-2.5 text-sm text-[#4d4d4d]">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-emerald-500 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <button id="pricing-cta-btn" class="flex items-center justify-center h-10 rounded-md bg-[#171717] text-white text-sm font-medium hover:bg-[#2d2d2d] transition-all cursor-pointer w-full">
              Get started free
            </button>
          </div>

          <!-- Pro tier (polarity-flipped / featured) -->
          <div class="rounded-xl bg-[#171717] p-7 flex flex-col relative overflow-hidden" style="box-shadow: 0px 1px 1px #00000005, 0px 2px 2px #0000000a, 0px 8px 16px -4px #0000001a;">
            <div class="absolute top-4 right-4">
              <span class="text-[10px] font-mono uppercase tracking-widest px-2.5 py-1 rounded-full bg-white/10 text-white/60 border border-white/15">Coming soon</span>
            </div>
            <div class="mb-5">
              <div class="text-xs font-mono text-white/40 uppercase tracking-widest mb-2">Pro</div>
              <div class="text-4xl font-semibold text-white mb-1" style="letter-spacing: -1px;">$29<span class="text-xl text-white/40 font-normal">/mo</span></div>
              <p class="text-sm text-white/40">Unlimited Apify credits included</p>
            </div>
            <ul class="space-y-2.5 mb-7 flex-1">
              {['Everything in Starter', 'Unlimited leads', 'Email enrichment (Hunter.io)', 'Email verification (ZeroBounce)', 'Google Places enrichment', 'Priority support'].map((f) => (
                <li class="flex items-center gap-2.5 text-sm text-white/70">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-white/40 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <button disabled class="flex items-center justify-center h-10 rounded-md bg-white/10 text-sm font-medium text-white/40 cursor-not-allowed border border-white/10">
              Notify me when available
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── FINAL CTA ──────────────────────────────────── -->
    <section class="px-6 py-24 border-t border-[#ebebeb] bg-[#171717]">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl sm:text-4xl font-semibold text-white mb-4" style="letter-spacing: -1px;">
          Start finding leads today.
        </h2>
        <p class="text-white/50 text-lg mb-8 max-w-md mx-auto">
          Self-hosted, private, and free to start. All you need is a free Apify account.
        </p>
        <div class="flex items-center justify-center gap-3 flex-wrap">
          {user ? (
            <a
              href="/dashboard"
              class="inline-flex items-center gap-2 px-6 h-12 text-base font-medium text-[#171717] bg-white hover:bg-[#fafafa] rounded-full transition-all no-underline"
            >
              Open dashboard
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          ) : (
            <>
              <button
                id="footer-cta-btn"
                class="inline-flex items-center gap-2 px-6 h-12 text-base font-medium text-[#171717] bg-white hover:bg-[#fafafa] rounded-full transition-all cursor-pointer"
              >
                Get started free
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
              </button>
            </>
          )}
        </div>
      </div>
    </section>

    <!-- ─── FOOTER ─────────────────────────────────────── -->
    <footer class="border-t border-[#ebebeb] px-6 py-12 bg-white">
      <div class="mx-auto max-w-5xl">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
          <div class="flex items-center gap-2.5">
            <div class="w-6 h-6 rounded-md flex items-center justify-center shrink-0" style="background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 60%, #a855f7 100%);">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none">
                <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z" fill="white" fill-opacity="0.9"/>
                <circle cx="12" cy="10" r="3" fill="white" fill-opacity="0.4"/>
              </svg>
            </div>
            <span class="text-sm font-semibold text-[#4d4d4d]">LeadScraper</span>
            <span class="text-[#d4d4d4]">·</span>
            <span class="text-xs text-[#a1a1a1]">leadscrape.io</span>
          </div>
          <div class="flex items-center gap-6">
            <a href="/dashboard" class="text-xs text-[#888888] hover:text-[#171717] transition-colors no-underline">Dashboard</a>
            <a href="/results"   class="text-xs text-[#888888] hover:text-[#171717] transition-colors no-underline">Results</a>
            <a href="/settings"  class="text-xs text-[#888888] hover:text-[#171717] transition-colors no-underline">Settings</a>
          </div>
          <p class="text-xs text-[#a1a1a1]">© 2025 LeadScraper. Self-hosted.</p>
        </div>
      </div>
    </footer>
  </main>

  <!-- Auth modal -->
  <AuthModal
    client:load
    supabaseUrl={supabaseConfig.url}
    supabaseKey={supabaseConfig.key}
  />

  <script>
    function openSignup() {
      document.dispatchEvent(new CustomEvent('open-auth-modal', { detail: { tab: 'signup' } }))
    }
    document.getElementById('hero-cta-btn')?.addEventListener('click', openSignup)
    document.getElementById('pricing-cta-btn')?.addEventListener('click', openSignup)
