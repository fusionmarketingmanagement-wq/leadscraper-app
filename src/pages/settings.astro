---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import SettingsPanel from '../components/SettingsPanel';
---

<Layout title="Settings">
  <Navbar variant="app" />

  <main class="mx-auto max-w-2xl px-6 py-10">

    <!-- Page header -->
    <div class="mb-8">
      <div class="flex items-center gap-1.5 text-xs text-[#a1a1a1] mb-3 font-mono">
        <a href="/" class="hover:text-[#4d4d4d] transition-colors no-underline">Home</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-[#d4d4d4]"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-[#888888]">Settings</span>
      </div>
      <h1 class="text-2xl font-semibold text-[#171717] tracking-tight mb-1" style="letter-spacing: -0.6px;">Settings</h1>
      <p class="text-[#888888] text-sm">Configure your API keys and manage stored data.</p>
    </div>

    <SettingsPanel client:load />

  </main>
</Layout>
