---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ResultsTable from '../components/ResultsTable';
---

<Layout title="Results">
  <Navbar variant="app" />

  <main class="mx-auto max-w-7xl px-6 py-10">

    <!-- Page header -->
    <div class="flex items-start justify-between mb-8 gap-4 flex-wrap">
      <div>
        <div class="flex items-center gap-1.5 text-xs text-[#a1a1a1] mb-3 font-mono">
          <a href="/" class="hover:text-[#4d4d4d] transition-colors no-underline">Home</a>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-[#d4d4d4]"><path d="m9 18 6-6-6-6"/></svg>
          <span class="text-[#888888]">Results</span>
        </div>
        <h1 class="text-2xl font-semibold text-[#171717] tracking-tight mb-1" style="letter-spacing: -0.6px;">Lead Database</h1>
        <p class="text-[#888888] text-sm">All scraped business leads stored in your Supabase database.</p>
      </div>

      <div class="flex items-center gap-2.5">
        <a
          href="/dashboard/leads"
          class="inline-flex items-center gap-2 px-4 h-9 rounded-md border border-[#ebebeb] bg-white text-sm text-[#4d4d4d] hover:text-[#171717] hover:border-[#a1a1a1] transition-all no-underline"
        >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          New search
        </a>
        <a
          href="/api/export"
          class="inline-flex items-center gap-2 px-4 h-9 rounded-md bg-[#171717] text-white text-sm font-medium hover:bg-[#2d2d2d] transition-all no-underline"
        >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Export CSV
        </a>
      </div>
    </div>

    <ResultsTable client:load />

  </main>
</Layout>
