---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'LeadScraper',
  description = 'Find verified business leads in seconds using Google Maps data.',
} = Astro.props;

const pageTitle = title === 'LeadScraper'
  ? 'LeadScraper — Find Business Leads at Scale'
  : `${title} — LeadScraper`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#0a0a0a] text-white min-h-screen font-sans antialiased">
    <slot />
  </body>
</html>
